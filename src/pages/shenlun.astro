---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="申论学习记录">
  <div class="min-h-screen bg-gradient-to-br from-dark-900 via-dark-800 to-dark-900 py-12 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">申论学习记录</h1>
        <p class="text-accent-400 text-lg">上传试题文档，记录你的答案与思考</p>
        <p class="text-white/40 text-sm mt-2">所有用户共享数据，可查看他人上传的试卷</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-8">
        <div class="lg:col-span-1">
          <div class="bg-dark-800/50 backdrop-blur-sm border border-white/10 rounded-2xl p-6 sticky top-24">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-2xl font-semibold text-white flex items-center gap-3">
                <svg class="w-6 h-6 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                </svg>
                试卷列表
              </h2>
              <span id="paperCount" class="text-sm text-white/40">(0 份)</span>
            </div>
            
            <div id="paperList" class="space-y-3 max-h-[600px] overflow-y-auto">
              <p class="text-white/40 text-center py-8">加载中...</p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="bg-dark-800/50 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-2xl font-semibold text-white flex items-center gap-3">
                <svg class="w-6 h-6 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                </svg>
                上传试题文档
              </h2>
              <button id="savePaper" class="bg-accent-300 hover:bg-accent-200 text-dark-900 font-semibold py-2 px-4 rounded-lg transition-colors flex items-center gap-2 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"/>
                </svg>
                保存试卷
              </button>
            </div>
            
            <div id="uploadArea" class="border-2 border-dashed border-white/20 rounded-xl p-8 text-center hover:border-accent-300 transition-colors cursor-pointer">
              <input type="file" id="fileInput" accept=".pdf,.doc,.docx" class="hidden" />
              <svg class="w-16 h-16 text-white/30 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              <p class="text-white/60 mb-2">点击或拖拽文件到此处</p>
              <p class="text-white/40 text-sm">支持 PDF、Word 文档</p>
            </div>

            <div id="fileInfo" class="hidden mt-4 p-4 bg-dark-700/50 rounded-lg">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <svg class="w-8 h-8 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  <div>
                    <p id="fileName" class="text-white font-medium"></p>
                    <p id="fileSize" class="text-white/40 text-sm"></p>
                  </div>
                </div>
                <button id="clearFile" class="text-red-400 hover:text-red-300 transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
              </div>
            </div>

            <div id="loadingIndicator" class="hidden mt-4 p-4 bg-dark-700/50 rounded-lg">
              <div class="flex items-center gap-3">
                <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-accent-300"></div>
                <p class="text-white/60">正在解析文档...</p>
              </div>
            </div>
          </div>

          <div class="bg-dark-800/50 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
            <h2 class="text-2xl font-semibold text-white mb-6 flex items-center gap-3">
              <svg class="w-6 h-6 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              试题内容
            </h2>
            
            <div id="questionContent" class="bg-dark-700/30 rounded-xl p-6 min-h-[300px] max-h-[500px] overflow-y-auto">
              <p class="text-white/40 text-center py-12">上传文档后将在此显示试题内容</p>
            </div>
          </div>

          <div class="bg-dark-800/50 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
            <h2 class="text-2xl font-semibold text-white mb-6 flex items-center gap-3">
              <svg class="w-6 h-6 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              答案输入
            </h2>
            
            <div class="space-y-4">
              <textarea 
                id="answerInput" 
                class="w-full bg-dark-700/30 border border-white/10 rounded-xl p-4 text-white placeholder-white/40 focus:outline-none focus:border-accent-300 transition-colors resize-none"
                rows="6"
                placeholder="在此输入你的答案..."
              ></textarea>
              
              <div class="flex gap-4">
                <button id="saveAnswer" class="flex-1 bg-accent-300 hover:bg-accent-200 text-dark-900 font-semibold py-3 px-6 rounded-xl transition-colors flex items-center justify-center gap-2">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  保存答案
                </button>
                <button id="clearAnswers" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 font-semibold py-3 px-6 rounded-xl transition-colors border border-red-500/30">
                  清空当前答案
                </button>
              </div>
            </div>
          </div>

          <div id="answersSection" class="bg-dark-800/50 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
            <h2 class="text-2xl font-semibold text-white mb-6 flex items-center gap-3">
              <svg class="w-6 h-6 text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
              </svg>
              已保存的答案
              <span id="answerCount" class="text-sm text-white/40 font-normal">(0 条)</span>
            </h2>
            
            <div id="answersList" class="space-y-4">
              <p class="text-white/40 text-center py-8">暂无保存的答案</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BlogLayout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import * as pdfjsLib from 'pdfjs-dist';
  import mammoth from 'mammoth';

  const supabaseUrl = import.meta.env.SUPABASE_URL;
  const supabaseAnonKey = import.meta.env.SUPABASE_ANON_KEY;

  if (!supabaseUrl || !supabaseAnonKey) {
    throw new Error('Missing Supabase environment variables');
  }

  const supabase = createClient(supabaseUrl, supabaseAnonKey);
  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.js';

  interface Paper {
    id: string;
    file_name: string;
    question_text: string;
    created_at: string;
    updated_at: string;
  }

  interface Answer {
    id: string;
    paper_id: string;
    content: string;
    created_at: string;
  }

  let currentPaperId: string | null = null;
  let currentFile: File | null = null;
  let currentQuestionText: string = '';
  let currentAnswers: Answer[] = [];

  const uploadArea = document.getElementById('uploadArea');
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const fileInfo = document.getElementById('fileInfo');
  const fileName = document.getElementById('fileName');
  const fileSize = document.getElementById('fileSize');
  const clearFileBtn = document.getElementById('clearFile');
  const loadingIndicator = document.getElementById('loadingIndicator');
  const questionContent = document.getElementById('questionContent');
  const answerInput = document.getElementById('answerInput') as HTMLTextAreaElement;
  const saveAnswerBtn = document.getElementById('saveAnswer');
  const clearAnswersBtn = document.getElementById('clearAnswers');
  const answersList = document.getElementById('answersList');
  const answerCount = document.getElementById('answerCount');
  const savePaperBtn = document.getElementById('savePaper');
  const paperList = document.getElementById('paperList');
  const paperCount = document.getElementById('paperCount');

  uploadArea?.addEventListener('click', () => fileInput?.click());

  uploadArea?.addEventListener('dragover', (e) => {
    e.preventDefault();
    e.stopPropagation();
    uploadArea.classList.add('border-accent-300');
  });

  uploadArea?.addEventListener('dragleave', (e) => {
    e.preventDefault();
    e.stopPropagation();
    uploadArea.classList.remove('border-accent-300');
  });

  uploadArea?.addEventListener('drop', (e) => {
    e.preventDefault();
    e.stopPropagation();
    uploadArea.classList.remove('border-accent-300');
    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      handleFile(files[0]);
    }
  });

  fileInput?.addEventListener('change', (e) => {
    const files = (e.target as HTMLInputElement).files;
    if (files && files.length > 0) {
      handleFile(files[0]);
    }
  });

  clearFileBtn?.addEventListener('click', () => {
    clearCurrentEditing();
  });

  function clearCurrentEditing() {
    if (fileInput) fileInput.value = '';
    if (fileInfo) fileInfo.classList.add('hidden');
    if (questionContent) {
      questionContent.innerHTML = '<p class="text-white/40 text-center py-12">上传文档后将在此显示试题内容</p>';
    }
    currentFile = null;
    currentQuestionText = '';
    currentAnswers = [];
    currentPaperId = null;
    renderAnswers();
  }

  async function handleFile(file: File) {
    const validTypes = [
      'application/pdf',
      'application/msword',
      'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
    ];

    if (!validTypes.includes(file.type)) {
      alert('请上传 PDF 或 Word 文档');
      return;
    }

    currentFile = file;
    if (fileInfo) fileInfo.classList.remove('hidden');
    if (fileName) fileName.textContent = file.name;
    if (fileSize) fileSize.textContent = formatFileSize(file.size);
    if (loadingIndicator) loadingIndicator.classList.remove('hidden');

    try {
      let text = '';

      if (file.type === 'application/pdf') {
        text = await extractTextFromPDF(file);
      } else {
        text = await extractTextFromWord(file);
      }

      currentQuestionText = text;
      if (questionContent) {
        questionContent.innerHTML = `<div class="text-white whitespace-pre-wrap">${escapeHtml(text)}</div>`;
      }

      currentAnswers = [];
      currentPaperId = null;
      renderAnswers();

    } catch (error) {
      console.error('Error extracting text:', error);
      if (questionContent) {
        questionContent.innerHTML = '<p class="text-red-400 text-center py-12">文档解析失败，请重试</p>';
      }
    } finally {
      if (loadingIndicator) loadingIndicator.classList.add('hidden');
    }
  }

  async function extractTextFromPDF(file: File): Promise<string> {
    const arrayBuffer = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
    let fullText = '';

    for (let i = 1; i <= pdf.numPages; i++) {
      const page = await pdf.getPage(i);
      const textContent = await page.getTextContent();
      const pageText = textContent.items
        .map((item: any) => item.str)
        .join(' ');
      fullText += pageText + '\n\n';
    }

    return fullText.trim();
  }

  async function extractTextFromWord(file: File): Promise<string> {
    const arrayBuffer = await file.arrayBuffer();
    const result = await mammoth.extractRawText({ arrayBuffer });
    return result.value;
  }

  function formatFileSize(bytes: number): string {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  saveAnswerBtn?.addEventListener('click', async () => {
    const answer = answerInput?.value.trim();
    if (!answer) {
      alert('请输入答案内容');
      return;
    }

    if (!currentPaperId) {
      currentAnswers.push({
        id: Date.now().toString(),
        paper_id: '',
        content: answer,
        created_at: new Date().toISOString()
      });
      if (answerInput) answerInput.value = '';
      renderAnswers();
      return;
    }

    try {
      const { data, error } = await supabase
        .from('answers')
        .insert({
          paper_id: currentPaperId,
          content: answer
        })
        .select()
        .single();

      if (error) throw error;

      currentAnswers.push(data);
      if (answerInput) answerInput.value = '';
      renderAnswers();
    } catch (error) {
      console.error('Error saving answer:', error);
      alert('保存答案失败');
    }
  });

  clearAnswersBtn?.addEventListener('click', async () => {
    if (confirm('确定要清空当前所有答案吗？此操作不可恢复。')) {
      if (!currentPaperId) {
        currentAnswers = [];
        renderAnswers();
        return;
      }

      try {
        const { error } = await supabase
          .from('answers')
          .delete()
          .eq('paper_id', currentPaperId);

        if (error) throw error;

        currentAnswers = [];
        renderAnswers();
      } catch (error) {
        console.error('Error clearing answers:', error);
        alert('清空答案失败');
      }
    }
  });

  savePaperBtn?.addEventListener('click', async () => {
    if (!currentQuestionText) {
      alert('请先上传试题文档');
      return;
    }

    const paperName = prompt('请输入试卷名称：', currentFile?.name || '未命名试卷');
    if (!paperName) return;

    try {
      if (currentPaperId) {
        const { error } = await supabase
          .from('papers')
          .update({
            file_name: paperName,
            question_text: currentQuestionText
          })
          .eq('id', currentPaperId);

        if (error) throw error;
      } else {
        const { data, error } = await supabase
          .from('papers')
          .insert({
            file_name: paperName,
            question_text: currentQuestionText
          })
          .select()
          .single();

        if (error) throw error;
        currentPaperId = data.id;

        if (currentAnswers.length > 0) {
          const answersToInsert = currentAnswers.map(a => ({
            paper_id: currentPaperId,
            content: a.content
          }));

          const { error: answersError } = await supabase
            .from('answers')
            .insert(answersToInsert);

          if (answersError) throw answersError;
        }
      }

      await loadPapers();
      alert('试卷保存成功！');
    } catch (error) {
      console.error('Error saving paper:', error);
      alert('保存试卷失败: ' + (error as any).message);
    }
  });

  async function loadPapers() {
    try {
      const { data, error } = await supabase
        .from('papers')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) throw error;

      if (paperCount) {
        paperCount.textContent = `(${data?.length || 0} 份)`;
      }

      if (!paperList) return;

      if (!data || data.length === 0) {
        paperList.innerHTML = '<p class="text-white/40 text-center py-8">暂无保存的试卷</p>';
        return;
      }

      paperList.innerHTML = data.map((paper: Paper) => `
        <div class="bg-dark-700/30 rounded-lg p-4 border ${currentPaperId === paper.id ? 'border-accent-300' : 'border-white/5'} hover:border-accent-300/50 transition-colors cursor-pointer paper-item" data-id="${paper.id}">
          <div class="flex items-start justify-between gap-2">
            <div class="flex-1 min-w-0">
              <h3 class="text-white font-medium truncate">${escapeHtml(paper.file_name)}</h3>
              <div class="flex items-center gap-2 mt-1 text-xs text-white/40">
                <span>${formatDate(paper.created_at)}</span>
              </div>
            </div>
            <button 
              class="delete-paper text-red-400 hover:text-red-300 transition-colors p-1 flex-shrink-0"
              data-id="${paper.id}"
              onclick="event.stopPropagation();"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        </div>
      `).join('');

      paperList.querySelectorAll('.paper-item').forEach(item => {
        item.addEventListener('click', (e) => {
          const id = (e.currentTarget as HTMLElement).dataset.id;
          if (id) {
            loadPaper(id);
          }
        });
      });

      paperList.querySelectorAll('.delete-paper').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const id = (e.currentTarget as HTMLElement).dataset.id;
          if (id && confirm('确定要删除这份试卷吗？')) {
            await deletePaper(id);
          }
        });
      });
    } catch (error) {
      console.error('Error loading papers:', error);
      if (paperList) {
        paperList.innerHTML = '<p class="text-red-400 text-center py-8">加载失败，请检查数据库配置</p>';
      }
    }
  }

  async function loadPaper(paperId: string) {
    try {
      const { data: paper, error: paperError } = await supabase
        .from('papers')
        .select('*')
        .eq('id', paperId)
        .single();

      if (paperError) throw paperError;

      const { data: answers, error: answersError } = await supabase
        .from('answers')
        .select('*')
        .eq('paper_id', paperId)
        .order('created_at', { ascending: true });

      if (answersError) throw answersError;

      currentPaperId = paperId;
      currentQuestionText = paper.question_text;
      currentAnswers = answers || [];

      if (fileInfo) fileInfo.classList.remove('hidden');
      if (fileName) fileName.textContent = paper.file_name;
      if (fileSize) fileSize.textContent = '已加载';
      if (questionContent) {
        questionContent.innerHTML = `<div class="text-white whitespace-pre-wrap">${escapeHtml(paper.question_text)}</div>`;
      }

      renderAnswers();
      await loadPapers();
    } catch (error) {
      console.error('Error loading paper:', error);
      alert('加载试卷失败');
    }
  }

  async function deletePaper(paperId: string) {
    try {
      const { error } = await supabase
        .from('papers')
        .delete()
        .eq('id', paperId);

      if (error) throw error;

      if (currentPaperId === paperId) {
        clearCurrentEditing();
      }

      await loadPapers();
    } catch (error) {
      console.error('Error deleting paper:', error);
      alert('删除试卷失败');
    }
  }

  function renderAnswers() {
    if (answerCount) {
      answerCount.textContent = `(${currentAnswers.length} 条)`;
    }

    if (!answersList) return;

    if (currentAnswers.length === 0) {
      answersList.innerHTML = '<p class="text-white/40 text-center py-8">暂无保存的答案</p>';
      return;
    }

    answersList.innerHTML = currentAnswers.map((answer, index) => `
      <div class="bg-dark-700/30 rounded-xl p-4 border border-white/5">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-accent-300 font-semibold">答案（${numberToChinese(index + 1)}）</span>
              <span class="text-white/40 text-sm">${formatTimestamp(answer.created_at)}</span>
            </div>
            <p class="text-white whitespace-pre-wrap">${escapeHtml(answer.content)}</p>
          </div>
          <button 
            class="delete-answer text-red-400 hover:text-red-300 transition-colors p-2"
            data-id="${answer.id}"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </button>
        </div>
      </div>
    `).join('');

    answersList.querySelectorAll('.delete-answer').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = (e.currentTarget as HTMLElement).dataset.id;
        if (id && confirm('确定要删除这条答案吗？')) {
          if (!currentPaperId) {
            currentAnswers = currentAnswers.filter(a => a.id !== id);
            renderAnswers();
            return;
          }

          try {
            const { error } = await supabase
              .from('answers')
              .delete()
              .eq('id', id);

            if (error) throw error;

            currentAnswers = currentAnswers.filter(a => a.id !== id);
            renderAnswers();
          } catch (error) {
            console.error('Error deleting answer:', error);
            alert('删除答案失败');
          }
        }
      });
    });
  }

  function numberToChinese(num: number): string {
    const chineseNumbers = ['一', '二', '三', '四', '五', '六', '七', '八', '九', '十'];
    if (num <= 10) {
      return chineseNumbers[num - 1];
    } else if (num < 20) {
      return '十' + (num === 10 ? '' : chineseNumbers[num - 11]);
    } else {
      return num.toString();
    }
  }

  function formatTimestamp(timestamp: string): string {
    const date = new Date(timestamp);
    return date.toLocaleString('zh-CN', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit'
    });
  }

  function formatDate(timestamp: string): string {
    const date = new Date(timestamp);
    return date.toLocaleDateString('zh-CN', {
      month: '2-digit',
      day: '2-digit'
    });
  }

  loadPapers();
</script>
