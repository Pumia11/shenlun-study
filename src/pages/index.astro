---
import BlogLayout from '../layouts/BlogLayout.astro';
import BlogCard from '../components/BlogCard.astro';

const posts = [
  {
    title: '开始我的写作之旅',
    slug: 'my-first-post',
    excerpt: '这是我的第一篇博客文章，记录我开始写作的心路历程。',
    date: '2026-03-04',
    image: 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1920&q=80'
  },
  {
    title: '设计思维与创意',
    slug: 'design-thinking',
    excerpt: '探索设计思维如何帮助我们解决复杂问题，激发创意灵感。',
    date: '2026-03-01',
    image: 'https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=1920&q=80'
  },
  {
    title: '极简主义生活方式',
    slug: 'minimalist-life',
    excerpt: '少即是多，探索极简主义如何改变我的生活。',
    date: '2026-02-28',
    image: 'https://images.unsplash.com/photo-1494438639946-1ebd1d20bf85?w=1920&q=80'
  },
  {
    title: '技术与人文',
    slug: 'tech-and-humanity',
    excerpt: '在数字时代，如何保持技术与人文的平衡。',
    date: '2026-02-25',
    image: 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=1920&q=80'
  },
];
---

<BlogLayout title="首页">
  <section class="min-h-screen flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-dark-900 via-dark-800 to-dark-900"></div>
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative z-10 text-center px-6">
      <p class="text-accent-300 text-sm tracking-[0.3em] uppercase mb-6 animate-fade-in">
        欢迎来到
      </p>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white mb-8 animate-slide-up">
        我的博客
      </h1>
      <p class="text-accent-400 text-lg md:text-xl max-w-2xl mx-auto mb-12 animate-slide-up" style="animation-delay: 0.1s">
        记录生活、分享思考、探索世界
      </p>
      <a 
        href="#posts"
        class="inline-block px-8 py-3 border border-white/30 text-white text-sm tracking-widest uppercase hover:bg-white hover:text-dark-900 transition-all duration-300 animate-slide-up"
        style="animation-delay: 0.2s"
      >
        浏览文章
      </a>
    </div>
    
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </section>

  <section id="posts" class="bg-dark-900">
    {posts.map((post, index) => (
      <BlogCard {...post} />
    ))}
  </section>
</BlogLayout>
