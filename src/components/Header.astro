---
const navItems = [
  { name: '首页', href: '/' },
  { name: '文章', href: '/blog' },
  { name: '申论学习', href: '/shenlun' },
  { name: '关于', href: '/about' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-dark-900/80 backdrop-blur-md border-b border-white/5">
  <nav class="container mx-auto px-6 py-4">
    <div class="flex justify-between items-center">
      <a href="/" class="text-xl font-bold text-white tracking-tight hover:opacity-80 transition-opacity">
        MyBlog
      </a>
      <ul class="flex gap-8">
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href}
              class="text-accent-300 hover:text-white transition-colors text-sm tracking-wide"
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>
